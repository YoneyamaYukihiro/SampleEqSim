<Application x:Class="SampleEqSim.Equipment.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SampleEqSim.Equipment"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <!-- 共通スタイル -->
            <Style x:Key="StatusTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="4,2"/>
            </Style>
            <Style x:Key="GroupBoxStyle" TargetType="GroupBox">
                <Setter Property="Margin" Value="4"/>
                <Setter Property="Padding" Value="6"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>
            <Style x:Key="ActionButtonStyle" TargetType="Button">
                <Setter Property="Margin" Value="4,2"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="MinWidth" Value="100"/>
            </Style>
            <!-- LED状態色 -->
            <SolidColorBrush x:Key="LedGreen" Color="#22C55E"/>
            <SolidColorBrush x:Key="LedRed" Color="#EF4444"/>
            <SolidColorBrush x:Key="LedYellow" Color="#EAB308"/>
            <SolidColorBrush x:Key="LedGray" Color="#6B7280"/>
            <SolidColorBrush x:Key="LedBlue" Color="#3B82F6"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
