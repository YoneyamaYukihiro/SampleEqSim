<Window x:Class="SampleEqSim.Host.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:SampleEqSim.Host.Views.Converters"
        mc:Ignorable="d"
        Title="SECS/GEM Host Simulator" Height="800" Width="1150"
        Background="#F8FAFC">

    <Window.Resources>
        <conv:StringToLedBrushConverter x:Key="LedBrush"/>
        <conv:StringToForegroundConverter x:Key="FgConverter"/>

        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="3,2"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="CategoryBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#1E40AF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="LedIndicator" TargetType="Ellipse">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- ヘッダー -->
        <Border DockPanel.Dock="Top" Background="#1E293B" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Style="{StaticResource LedIndicator}"
                             Fill="{Binding ConnectionLedBrush, Converter={StaticResource LedBrush}}"
                             Width="14" Height="14"/>
                    <TextBlock Text="SECS/GEM Host Simulator  (Active / 127.0.0.1:5000)"
                               FontSize="15" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="  |  " Foreground="#475569" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ConnectionStateText}" FontSize="13"
                               Foreground="{Binding ConnectionLedBrush, Converter={StaticResource LedBrush}}"
                               VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding CurrentTime}"
                           FontSize="13" Foreground="#94A3B8" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- 装置情報バー -->
        <Border DockPanel.Dock="Top" Background="#334155" Padding="12,6">
            <UniformGrid Rows="1" Columns="5">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Model:" Foreground="#94A3B8" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding EquipmentModel}" Foreground="White" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="SoftRev:" Foreground="#94A3B8" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding EquipmentSoftRev}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="DateTime:" Foreground="#94A3B8" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding EquipmentDateTime}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="CtrlState:" Foreground="#94A3B8" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding EquipmentControlState}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="ProcState:" Foreground="#94A3B8" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding EquipmentProcState}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </UniformGrid>
        </Border>

        <!-- メインコンテンツ -->
        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左パネル: コマンド -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,8,0">
                <StackPanel>

                    <!-- 接続管理 (Stream 1) -->
                    <GroupBox Header="接続管理 (Stream 1)" Margin="0,0,0,6" Padding="6">
                        <StackPanel>
                            <Button Content="S1F1  Are You There" Style="{StaticResource Btn}"
                                    Command="{Binding SendS1F1Command}"/>
                            <Button Content="S1F13 Establish Communications" Style="{StaticResource Btn}"
                                    Command="{Binding SendS1F13Command}"/>
                            <Button Content="S1F17 Request ON-LINE" Style="{StaticResource Btn}"
                                    Command="{Binding SendS1F17Command}"/>
                            <Button Content="S1F15 Request OFF-LINE" Style="{StaticResource Btn}"
                                    Command="{Binding SendS1F15Command}"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- 装置制御 (Stream 2) -->
                    <GroupBox Header="装置制御 (Stream 2)" Margin="0,0,0,6" Padding="6">
                        <StackPanel>
                            <Button Content="S2F17 Date/Time Request" Style="{StaticResource Btn}"
                                    Command="{Binding SendS2F17Command}"/>
                            <!-- ホストコマンド -->
                            <Separator Margin="0,4"/>
                            <TextBlock Text="S2F41 Host Command:" FontSize="11" Margin="0,2"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding HostCommandText, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="4,4" FontSize="11"/>
                                <Button Grid.Column="1" Content="送信" Style="{StaticResource Btn}"
                                        Command="{Binding SendHostCommandCommand}"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <Button Content="START" Style="{StaticResource Btn}">
                                    <Button.Command>
                                        <Binding Path="SendHostCommandCommand"/>
                                    </Button.Command>
                                </Button>
                                <Button Content="STOP" Style="{StaticResource Btn}"
                                        Command="{Binding SendHostCommandCommand}"/>
                                <Button Content="PAUSE" Style="{StaticResource Btn}"
                                        Command="{Binding SendHostCommandCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- データ収集設定 -->
                    <GroupBox Header="データ収集設定" Margin="0,0,0,6" Padding="6">
                        <StackPanel>
                            <Button Content="S2F33 Define Report (RPTID=1)" Style="{StaticResource Btn}"
                                    Command="{Binding DefineReportCommand}"/>
                            <Button Content="S2F35 Link Event Report" Style="{StaticResource Btn}"
                                    Command="{Binding LinkEventReportCommand}"/>
                            <Button Content="S2F37 Enable All Events" Style="{StaticResource Btn}"
                                    Command="{Binding EnableAllEventsCommand}"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- ステータス変数 -->
                    <GroupBox Header="ステータス変数 (S1F3)" Margin="0,0,0,6" Padding="6">
                        <StackPanel>
                            <TextBlock Text="SVID (カンマ区切り):" FontSize="11"/>
                            <TextBox Text="{Binding RequestSvIds, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="4,4" FontSize="11" Margin="0,2"/>
                            <Button Content="S1F3 SV Request" Style="{StaticResource Btn}"
                                    Command="{Binding RequestStatusVariablesCommand}"/>
                            <TextBox Text="{Binding SvDataResult, Mode=OneWay}"
                                     IsReadOnly="True" FontFamily="Consolas" FontSize="10"
                                     Background="#F1F5F9" Padding="4" MinHeight="50"
                                     TextWrapping="Wrap" Margin="0,2"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- アラーム -->
                    <GroupBox Header="アラーム管理 (Stream 5)" Margin="0,0,0,6" Padding="6">
                        <StackPanel>
                            <Button Content="S5F5 List Alarms" Style="{StaticResource Btn}"
                                    Command="{Binding ListAlarmsCommand}"/>
                        </StackPanel>
                    </GroupBox>

                </StackPanel>
            </ScrollViewer>

            <!-- 右パネル: ログ + イベントログ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="180"/>
                </Grid.RowDefinitions>

                <!-- 通信ログ -->
                <Grid Grid.Row="0" Margin="0,0,0,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,4">
                        <TextBlock Text="通信ログ (Message Log)" FontSize="13" FontWeight="Bold"
                                   Foreground="#334155" VerticalAlignment="Center"/>
                        <Button HorizontalAlignment="Right" Content="ログクリア" Style="{StaticResource Btn}"
                                Command="{Binding ClearLogCommand}"/>
                    </Grid>
                    <Border Grid.Row="1" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4">
                        <ListView ItemsSource="{Binding MessageLog}"
                                  FontFamily="Consolas" FontSize="11"
                                  Background="#0F172A"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="時刻" Width="85">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding TimeText}" Foreground="#94A3B8" FontSize="10"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="メッセージ" Width="600">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Message}"
                                                           Foreground="{Binding ForegroundColor, Converter={StaticResource FgConverter}}"
                                                           FontSize="11"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="2,1"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </Border>
                </Grid>

                <!-- イベントログ -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,4">
                        <TextBlock Text="イベント・アラームログ" FontSize="13" FontWeight="Bold"
                                   Foreground="#334155" VerticalAlignment="Center"/>
                        <Button HorizontalAlignment="Right" Content="クリア" Style="{StaticResource Btn}"
                                Command="{Binding ClearEventLogCommand}"/>
                    </Grid>
                    <Border Grid.Row="1" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4">
                        <ListBox ItemsSource="{Binding EventLog}"
                                 FontFamily="Consolas" FontSize="11"
                                 Background="#1E293B" Foreground="#FCD34D"
                                 VirtualizingPanel.IsVirtualizing="True"/>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
